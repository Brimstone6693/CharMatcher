```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.out

# Coverage
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
```